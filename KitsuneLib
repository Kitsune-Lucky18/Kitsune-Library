function Kitsune:CreateWindow(cfg)
    self:Intro()

    local gui = Instance.new("ScreenGui", LocalPlayer.PlayerGui)

    -- BLUR
    local blur = Instance.new("BlurEffect", game.Lighting)
    blur.Size = 10

    local main = Instance.new("Frame", gui)
    main.Size = UDim2.new(0,650,0,400)
    main.Position = UDim2.new(0.5,-325,0.5,-200)
    main.BackgroundColor3 = Color3.fromRGB(15,15,20)
    Instance.new("UICorner", main)

    local stroke = Instance.new("UIStroke", main)
    stroke.Color = Color3.fromRGB(255,120,80)

    Drag(main)

    local top = Instance.new("Frame", main)
    top.Size = UDim2.new(1,0,0,40)
    top.BackgroundTransparency = 1

    local title = Instance.new("TextLabel", top)
    title.Size = UDim2.new(1,-80,1,0)
    title.Text = cfg.Name or "Kitsune Hub"
    title.TextColor3 = Color3.fromRGB(255,120,80)
    title.BackgroundTransparency = 1

    local close = Instance.new("TextButton", top)
    close.Size = UDim2.new(0,40,1,0)
    close.Position = UDim2.new(1,-40,0,0)
    close.Text = "-"

    local reopen = Instance.new("TextButton", gui)
    reopen.Size = UDim2.new(0,100,0,30)
    reopen.Position = UDim2.new(0,10,0.5,0)
    reopen.Text = "Open UI"
    reopen.Visible = false

    local opened=true

    close.MouseButton1Click:Connect(function()
        opened=not opened
        main.Visible=opened
        reopen.Visible=not opened
    end)

    reopen.MouseButton1Click:Connect(function()
        main.Visible=true
        reopen.Visible=false
    end)

    local tabs = Instance.new("Frame", main)
    tabs.Size = UDim2.new(0,160,1,-40)
    tabs.Position = UDim2.new(0,0,0,40)

    local tabLayout = Instance.new("UIListLayout", tabs)
    tabLayout.Padding = UDim.new(0,5)

    local content = Instance.new("Frame", main)
    content.Size = UDim2.new(1,-160,1,-40)
    content.Position = UDim2.new(0,160,0,40)

    local Window = {}

    function Window:CreateTab(name,icon,premiumId)
        local btn = Instance.new("TextButton", tabs)
        btn.Size = UDim2.new(1,0,0,40)
        btn.Text = name

        local frame = Instance.new("ScrollingFrame", content)
        frame.Size = UDim2.new(1,0,1,0)
        frame.Visible=false
        frame.ScrollBarThickness=3

        local layout = Instance.new("UIListLayout", frame)
        layout.Padding = UDim.new(0,10)

        layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            frame.CanvasSize = UDim2.new(0,0,0,layout.AbsoluteContentSize.Y)
        end)

        btn.MouseButton1Click:Connect(function()
            if premiumId and not HasGamepass(premiumId) then
                MarketplaceService:PromptGamePassPurchase(LocalPlayer,premiumId)
                return
            end
            for _,v in pairs(content:GetChildren()) do
                if v:IsA("ScrollingFrame") then v.Visible=false end
            end
            frame.Visible=true
        end)

        local Tab = {}

        function Tab:CreateSection(text)
            local sec = Instance.new("Frame", frame)
            sec.Size = UDim2.new(1,-10,0,200)
            Instance.new("UICorner", sec)

            local list = Instance.new("UIListLayout", sec)
            list.Padding = UDim.new(0,6)

            local label = Instance.new("TextLabel", sec)
            label.Text = text
            label.Size = UDim2.new(1,0,0,20)
            label.BackgroundTransparency=1

            return {Frame=sec}
        end

        return Tab
    end

    function Window:Destroy()
        gui:Destroy()
        blur:Destroy()
    end

    return Window
end

