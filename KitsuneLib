function Kitsune:Intro()
    local g = Instance.new("ScreenGui", LocalPlayer.PlayerGui)
    local f = Instance.new("Frame", g)
    f.Size = UDim2.new(1,0,1,0)
    f.BackgroundColor3 = Color3.fromRGB(10,10,15)

    local t = Instance.new("TextLabel", f)
    t.Size = UDim2.new(1,0,1,0)
    t.Text = "🦊 Kitsune Loading..."
    t.TextColor3 = Color3.fromRGB(255,120,80)
    t.BackgroundTransparency = 1
    t.Font = Enum.Font.GothamBold
    t.TextSize = 28

    task.wait(1.5)
    TweenService:Create(f,TweenInfo.new(1),{BackgroundTransparency=1}):Play()
    task.wait(1)
    g:Destroy()
end

--------------------------------------------------
-- DRAG
--------------------------------------------------
local function Drag(frame)
    local drag=false
    local start,pos
    frame.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            drag=true
            start=i.Position
            pos=frame.Position
        end
    end)
    UIS.InputChanged:Connect(function(i)
        if drag and i.UserInputType==Enum.UserInputType.MouseMovement then
            local d=i.Position-start
            frame.Position=pos+UDim2.new(0,d.X,0,d.Y)
        end
    end)
    frame.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            drag=false
        end
    end)
end

